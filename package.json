{
  "name": "tweenlabs",
  "version": "0.1.6",
  "description": "Zero-dependency CLI to install premium GSAP animation components directly into your Next.js or React project.",
  "keywords": [
    "gsap",
    "animation",
    "nextjs",
    "react",
    "components",
    "cli",
    "tweenlabs",
    "scrolltrigger",
    "lenis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TweenLabs/TweenLabs.git"
  },
  "homepage": "https://tweenlabs.xyz",
  "bugs": {
    "url": "https://github.com/TweenLabs/TweenLabs/issues"
  },
  "bin": {
    "tweenlabs": "bin/cli.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev",
    "dev:stable": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --no-turbopack",
    "build": "node scripts/generate-llms-full.js && next build",
    "vercel-build": "convex deploy --cmd \"node scripts/generate-llms-full.js && next build\"",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@convex-dev/better-auth": "^0.12.4",
    "@gsap/react": "^2.1.2",
    "better-auth": "^1.6.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.41.0",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.15.0",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.23",
    "lucide-react": "^1.21.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
